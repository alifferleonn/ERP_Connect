# ==================================================
# DATABASE (SQLite Local)
# ==================================================
# Para desenvolvimento local, o banco SQLite será criado em prisma/dev.db

DATABASE_URL="file:./prisma/dev.db"

# ==================================================
# APPLICATION
# ==================================================

NEXT_PUBLIC_APP_NAME=Pharmix Global
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ==================================================
# SUPABASE (Opcional - será configurado depois)
# ==================================================
# Descomente quando quiser migrar para produção com Supabase
# NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=seu-chave-anonima
# SUPABASE_SERVICE_ROLE_KEY=sua-chave-service-role
